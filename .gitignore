# This repo uses pnpm workspaces. Do not commit npm lockfiles generated by
# accidental `npm install` runs in subprojects.
package-lock.json
**/package-lock.json

# Local installer/app bundles and mounted disk images are machine artifacts, not
# test fixtures. A copied Cursor.app once landed under harness/tests.
*.app/
*.dmg
*.pkg
* Installer/
Cursor Installer/
**/Cursor Installer/

# harness run artifacts — transient. Progress is recorded via git tags + LOGBOOK.md.
LOOPLOG.txt
harness/diagnosis-*.txt
harness/*.new
harness/**/*.new
harness/tmp/
harness/.playtest/
harness/.smoketest/
harness/tests/**/.tmp/
harness/tests/**/tmp/
harness/progress/events.ndjson
harness/progress/gpu-uptime.json
harness/progress/token-totals.json
harness/progress/.tunnel-credentials

# Agent / local scratch paths — machine-local, not repo content.
memory/
scratch/
temp_artifacts/
lobby.png/

tickets/**/artifacts/
tickets/**/qwen-openai-logs/
tickets/**/coverage-round-*/
tickets/**/review-round-*/
tickets/**/.reviews/
tickets/**/rescue/
tickets/**/rescue-review/
tickets/**/log.txt
tickets/**/feedback.md
tickets/**/handoff.md
tickets/**/review-feedback.md
tickets/**/decompose-round-*.txt
tickets/**/.passed

# Local playtest / walkthrough captures. Keep authored markdown/scripts checked
# in intentionally, but keep raw logs, screenshots, and generated result blobs
# out of normal git status.
game/docs/walkthroughs/**/*.log
game/docs/walkthroughs/**/*.png
game/docs/walkthroughs/**/*-results.json
game/client/scripts/*-results.json

# Python build artifacts. egg-info lands at repo root (not harness/) because
# pyproject.toml uses `where = [".."]` to make `harness` importable as a
# top-level package; setuptools then treats autogame/ as the project source.
autogame_harness.egg-info/
*.egg-info/
__pycache__/
*.py[cod]
.pytest_cache/
