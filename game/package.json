{
  "name": "autogame",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "check:deps": "node scripts/check_package_age.js",
    "dev": "concurrently \"pnpm -C server run dev\" \"pnpm -C client run dev\"",
    "install:all": "pnpm install",
    "test": "node scripts/run-vitest.mjs run --coverage --config vitest.config.js",
    "test:quick": "node scripts/run-vitest.mjs run --config vitest.config.js --coverage.enabled=false",
    "test:smoke:lobby-dropin": "node scripts/test-lobby-dropin.mjs",
    "test:smoke:lobby-browser": "node client/scripts/test-lobby-browser.mjs",
    "test:smoke:lock-on": "node client/scripts/test-lock-on.mjs",
    "test:smoke:keyitems": "node client/scripts/test-keyitems-capture.mjs",
    "test:smoke:p0": "PHASE=after node client/scripts/test-p0-bugs.mjs",
    "test:smoke:creature-burndown": "node client/scripts/test-creature-burndown.mjs",
    "test:smoke:deck-loadout": "node client/scripts/test-deck-loadout.mjs",
    "test:smoke:summon-combat": "node client/scripts/test-summon-combat.mjs",
    "test:smoke:summon-recall": "node client/scripts/test-summon-recall.mjs",
    "test:smoke:wyrm-breath": "node client/scripts/test-wyrm-breath.mjs",
    "test:smoke:quest-completion": "node client/scripts/test-quest-completion.mjs",
    "test:smoke:world-stage-transition": "node client/scripts/test-world-stage-transition.mjs",
    "test:smoke:telepipe-suspend-resume": "node client/scripts/test-telepipe-suspend-resume.mjs",
    "test:smoke:card-evolution": "node client/scripts/test-card-evolution.mjs",
    "cleanup:vitest": "bash scripts/kill-vitest.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "socket.io-client": "^4.8.3",
    "vitest": "^3.2.4"
  }
}
