  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "socket.io-client": "^4.8.3",
    "vitest": "^3.2.4"
  }
}
